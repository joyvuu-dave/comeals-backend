#!/usr/bin/env bash
set -euo pipefail

# ==============================================================================
# Comeals Deploy Script
#
# Deploys the backend (comeals-backend) and/or frontend (comeals-ui) to Heroku.
#
# Smart deploy logic:
#   1. Compares local HEAD vs Heroku's deployed SHA for each app independently.
#      Skips apps that are already up to date.
#   2. For the backend, diffs db/migrate/ between the deployed and local SHAs.
#      - If migrations changed → maintenance deploy (scale to 0, push, scale up).
#      - If no migrations    → push deploy (brief downtime during restart).
#   3. The frontend is always a simple push deploy (no database).
#   4. If neither app has changes, exits early with nothing to do.
#
# Both apps run 1× Basic dyno. Deploys cause brief downtime during dyno
# restart. Maintenance mode is only used when database migrations require it.
# ==============================================================================

BACKEND_PATH="/Users/tejo/workspace/comeals-backend"
FRONTEND_PATH="/Users/tejo/workspace/comeals-ui"
BACKEND_APP="comeals-backend"
FRONTEND_APP="comeals-ui"
FRONTEND_URL="https://comeals.com"
BACKEND_URL="https://admin.comeals.com"
MAINTENANCE_ENABLED=false
DEPLOY_TIMESTAMP=""
DEPLOY_BACKEND=false
DEPLOY_FRONTEND=false
NEEDS_MAINTENANCE=false
BACKEND_HEROKU_SHA=""

# --- Output helpers -----------------------------------------------------------

red()    { printf "\033[0;31m%s\033[0m\n" "$*"; }
green()  { printf "\033[0;32m%s\033[0m\n" "$*"; }
yellow() { printf "\033[0;33m%s\033[0m\n" "$*"; }
bold()   { printf "\033[1m%s\033[0m\n" "$*"; }

step() { printf "\n"; bold "==> $*"; }
info() { echo "    $*"; }
ok()   { green "    ✓ $*"; }
warn() { yellow "    ⚠ $*"; }
fail() { red "    ✗ $*"; }

# --- Cleanup trap -------------------------------------------------------------

cleanup() {
  local exit_code=$?
  if [ $exit_code -ne 0 ] && [ "$MAINTENANCE_ENABLED" = true ]; then
    echo
    red "============================================"
    red "  DEPLOY FAILED — MANUAL RECOVERY REQUIRED"
    red "============================================"
    echo
    yellow "Both apps may still be in maintenance mode."
    yellow "Web dynos may be scaled to 0."
    yellow "Investigate the failure, then manually run:"
    echo
    echo "  heroku ps:scale web=1 -a $BACKEND_APP"
    echo "  heroku ps:scale web=1 -a $FRONTEND_APP"
    echo "  heroku maintenance:off -a $BACKEND_APP"
    echo "  heroku maintenance:off -a $FRONTEND_APP"
    echo
  fi
}
trap cleanup EXIT

# --- Pre-flight checks --------------------------------------------------------

preflight_environment() {
  step "Pre-flight: environment"

  # heroku CLI installed?
  if ! command -v heroku &>/dev/null; then
    fail "heroku CLI not found in PATH"
    exit 1
  fi
  ok "heroku CLI found"

  # heroku authenticated?
  if ! heroku auth:whoami &>/dev/null; then
    fail "Not logged into Heroku (run: heroku login)"
    exit 1
  fi
  local user
  user=$(heroku auth:whoami 2>/dev/null)
  ok "Logged into Heroku as $user"

  # heroku git remotes exist?
  for pair in "$BACKEND_PATH:$BACKEND_APP" "$FRONTEND_PATH:$FRONTEND_APP"; do
    local path="${pair%%:*}"
    local app="${pair##*:}"
    local remote_url
    remote_url=$(git -C "$path" remote get-url heroku 2>/dev/null || true)
    if [ -z "$remote_url" ]; then
      fail "No 'heroku' git remote in $path"
      info "Run: heroku git:remote -a $app  (from $path)"
      exit 1
    fi
    ok "heroku remote in $path -> $remote_url"
  done
}

preflight_check() {
  local name="$1"
  local path="$2"

  step "Pre-flight: $name ($path)"
  cd "$path"

  # (a) On master branch?
  local branch
  branch=$(git rev-parse --abbrev-ref HEAD)
  if [ "$branch" != "master" ]; then
    fail "On branch '$branch', expected 'master'"
    exit 1
  fi
  ok "On master branch"

  # (b) No uncommitted changes?
  if [ -n "$(git status --porcelain)" ]; then
    fail "Uncommitted changes detected:"
    git status --short
    exit 1
  fi
  ok "Working tree clean"

  # (c + d) Fetch from origin, then check sync.
  # Deliberately NOT --all: fetching from heroku is unnecessary and would
  # fail the deploy if Heroku's git endpoint is temporarily unreachable.
  info "Fetching from origin..."
  git fetch origin -p -P --quiet

  local ahead behind
  ahead=$(git rev-list origin/master..HEAD --count)
  behind=$(git rev-list HEAD..origin/master --count)

  if [ "$ahead" -gt 0 ]; then
    fail "$ahead unpushed commit(s) on master"
    exit 1
  fi
  ok "No unpushed commits"

  if [ "$behind" -gt 0 ]; then
    info "Local is $behind commit(s) behind origin/master, pulling..."
    git pull --ff-only --quiet
    ok "Pulled $behind commit(s)"
  else
    ok "Up to date with origin/master"
  fi
}

preflight_backend_quality() {
  step "Pre-flight: backend linting & tests"
  cd "$BACKEND_PATH"

  info "Running RuboCop..."
  bundle exec rubocop --parallel
  ok "RuboCop passed"

  info "Running RSpec..."
  bundle exec rspec
  ok "RSpec passed"
}

preflight_frontend_quality() {
  step "Pre-flight: frontend linting & tests"
  cd "$FRONTEND_PATH"

  info "Running ESLint..."
  npx eslint src/
  ok "ESLint passed"

  info "Running Vitest..."
  npx vitest run
  ok "Vitest passed"

  info "Running Playwright e2e tests..."
  npx playwright test
  ok "Playwright passed"
}

# --- Deploy detection ---------------------------------------------------------

detect_deploy_needs() {
  step "Detecting what needs to deploy"

  # --- Backend ---
  local backend_local_sha backend_heroku_sha
  backend_local_sha=$(git -C "$BACKEND_PATH" rev-parse HEAD)
  backend_heroku_sha=$(git -C "$BACKEND_PATH" ls-remote heroku refs/heads/main 2>/dev/null | awk '{print $1}')

  if [ -z "$backend_heroku_sha" ]; then
    warn "Cannot read backend Heroku SHA (first deploy or endpoint unreachable)"
    info "Will deploy backend with maintenance mode for safety"
    DEPLOY_BACKEND=true
    NEEDS_MAINTENANCE=true
  elif [ "$backend_heroku_sha" = "$backend_local_sha" ]; then
    ok "Backend: up to date (${backend_local_sha:0:7})"
  else
    info "Backend: heroku=${backend_heroku_sha:0:7} -> local=${backend_local_sha:0:7}"
    DEPLOY_BACKEND=true
    BACKEND_HEROKU_SHA="$backend_heroku_sha"
  fi

  # --- Frontend ---
  local frontend_local_sha frontend_heroku_sha
  frontend_local_sha=$(git -C "$FRONTEND_PATH" rev-parse HEAD)
  frontend_heroku_sha=$(git -C "$FRONTEND_PATH" ls-remote heroku refs/heads/main 2>/dev/null | awk '{print $1}')

  if [ -z "$frontend_heroku_sha" ]; then
    warn "Cannot read frontend Heroku SHA (first deploy or endpoint unreachable)"
    info "Will deploy frontend"
    DEPLOY_FRONTEND=true
  elif [ "$frontend_heroku_sha" = "$frontend_local_sha" ]; then
    ok "Frontend: up to date (${frontend_local_sha:0:7})"
  else
    info "Frontend: heroku=${frontend_heroku_sha:0:7} -> local=${frontend_local_sha:0:7}"
    DEPLOY_FRONTEND=true
  fi
}

detect_pending_migrations() {
  local heroku_sha="$1"

  step "Checking for pending migrations"
  cd "$BACKEND_PATH"

  # Ensure heroku SHA exists in local object store.
  # It might be missing if history was rewritten via force push.
  if ! git cat-file -e "$heroku_sha" 2>/dev/null; then
    info "Heroku SHA not in local history (force push?) — fetching from Heroku..."
    if git fetch heroku main --quiet 2>/dev/null; then
      ok "Fetched Heroku main branch"
    else
      warn "Cannot fetch from Heroku — assuming migrations needed"
      NEEDS_MAINTENANCE=true
      return
    fi

    # Verify the SHA is now available after fetch
    if ! git cat-file -e "$heroku_sha" 2>/dev/null; then
      warn "Heroku SHA still not in object store after fetch — assuming migrations needed"
      NEEDS_MAINTENANCE=true
      return
    fi
  fi

  # Diff the migration directory between Heroku's version and local HEAD.
  # git diff A B compares two trees directly — works regardless of ancestry,
  # so this is correct even when history was rewritten via force push.
  local migration_diff
  if ! migration_diff=$(git diff --name-only "$heroku_sha" HEAD -- db/migrate/ 2>/dev/null); then
    warn "git diff failed — assuming migrations needed"
    NEEDS_MAINTENANCE=true
    return
  fi

  if [ -n "$migration_diff" ]; then
    NEEDS_MAINTENANCE=true
    warn "Migration changes detected — maintenance deploy required:"
    echo "$migration_diff" | while IFS= read -r f; do
      info "  $f"
    done
  else
    ok "No migration changes — push deploy"
  fi
}

# --- Deploy functions ---------------------------------------------------------

enable_maintenance() {
  step "Enabling maintenance mode"
  heroku maintenance:on -a "$BACKEND_APP"
  ok "$BACKEND_APP maintenance ON"
  heroku maintenance:on -a "$FRONTEND_APP"
  ok "$FRONTEND_APP maintenance ON"
  MAINTENANCE_ENABLED=true
}

disable_maintenance() {
  step "Disabling maintenance mode"
  heroku maintenance:off -a "$BACKEND_APP"
  ok "$BACKEND_APP maintenance OFF"
  heroku maintenance:off -a "$FRONTEND_APP"
  ok "$FRONTEND_APP maintenance OFF"
  MAINTENANCE_ENABLED=false
}

deploy_backend() {
  step "Deploying backend ($BACKEND_APP)"
  cd "$BACKEND_PATH"

  # Push deploy: dyno restarts with brief downtime. The release phase
  # (db:migrate) runs but is a no-op since there are no pending migrations.
  info "Pushing master:main to Heroku (no migrations)..."
  git push heroku master:main --force
  ok "Code pushed — release phase complete"

  # Flush stale cached serializer data. Non-fatal — a transient MemCachier
  # issue shouldn't block the deploy.
  info "Flushing MemCachier..."
  if heroku run bin/rails runner 'Rails.cache.clear' -a "$BACKEND_APP"; then
    ok "Cache flushed"
  else
    warn "Cache flush failed — stale entries may persist until naturally invalidated"
  fi

  # billing:recalculate refreshes a derived cache (resident_balances).
  # Failure is not catastrophic — stale balances are wrong but not dangerous.
  info "Running billing:recalculate..."
  if heroku run bin/rake billing:recalculate -a "$BACKEND_APP"; then
    ok "Billing recalculated"
  else
    warn "billing:recalculate failed — balances may be stale until next daily run"
  fi
}

deploy_backend_maintenance() {
  step "Deploying backend — maintenance ($BACKEND_APP)"
  cd "$BACKEND_PATH"

  info "Scaling web dynos to 0..."
  heroku ps:scale web=0 -a "$BACKEND_APP"
  ok "Web dynos scaled to 0"

  # git push is synchronous — it blocks until build AND release phase complete.
  # The release phase (Procfile: bin/rake db:migrate) runs migrations automatically.
  # If the release phase fails, git push exits non-zero and set -e aborts here.
  info "Pushing master:main to Heroku (release phase runs migrations)..."
  git push heroku master:main --force
  ok "Code pushed and migrations complete"

  # Flush stale cached serializer data. Non-fatal — a transient MemCachier
  # issue shouldn't leave the app down with 0 dynos and maintenance on.
  info "Flushing MemCachier..."
  if heroku run bin/rails runner 'Rails.cache.clear' -a "$BACKEND_APP"; then
    ok "Cache flushed"
  else
    warn "Cache flush failed — stale entries may persist until naturally invalidated"
  fi

  # billing:recalculate refreshes a derived cache (resident_balances).
  # Failure is not catastrophic — stale balances are wrong but not dangerous.
  info "Running billing:recalculate..."
  if heroku run bin/rake billing:recalculate -a "$BACKEND_APP"; then
    ok "Billing recalculated"
  else
    warn "billing:recalculate failed — balances may be stale until next daily run"
  fi

  info "Scaling web dyno back up..."
  heroku ps:scale web=1 -a "$BACKEND_APP"
  ok "Web dyno running"
}

deploy_frontend() {
  step "Deploying frontend ($FRONTEND_APP)"
  cd "$FRONTEND_PATH"

  info "Pushing master:main to Heroku..."
  git push heroku master:main --force
  ok "Code pushed"
}

deploy_frontend_maintenance() {
  step "Deploying frontend — maintenance ($FRONTEND_APP)"
  cd "$FRONTEND_PATH"

  info "Scaling web dynos to 0..."
  heroku ps:scale web=0 -a "$FRONTEND_APP"
  ok "Web dynos scaled to 0"

  info "Pushing master:main to Heroku..."
  git push heroku master:main --force
  ok "Code pushed"

  info "Scaling web dyno back up..."
  heroku ps:scale web=1 -a "$FRONTEND_APP"
  ok "Web dyno running"
}

capture_backup() {
  step "Capturing database backup"
  heroku pg:backups:capture -a "$BACKEND_APP"
  ok "Backup complete"

  local backup_info
  backup_info=$(heroku pg:backups:info -a "$BACKEND_APP" 2>&1 || true)
  info "$backup_info"
}

# --- Post-deploy checks ------------------------------------------------------

check_logs() {
  local app="$1"
  step "Checking post-deploy logs for $app"

  # Fetch recent logs. heroku logs doesn't support --since, so we fetch
  # a generous window and filter to lines after the deploy timestamp.
  local logs
  logs=$(heroku logs -n 200 -s app -a "$app" 2>&1 || true)

  # Filter to lines timestamped after the deploy started.
  # Heroku log lines start with: 2026-03-28T10:00:00.000000+00:00
  local app_logs
  app_logs=$(echo "$logs" | awk -v ts="$DEPLOY_TIMESTAMP" '$1 >= ts' || true)

  if [ -z "$app_logs" ]; then
    ok "No application log output since deploy"
    return 0
  fi

  local issues=""

  # Tight patterns: look for log-level prefixes and stack trace indicators,
  # not bare words like "error" which match normal log messages.
  local errors
  errors=$(echo "$app_logs" | grep -E "(ERROR|FATAL|RuntimeError|NoMethodError|NameError|TypeError|ArgumentError|PG::|Errno::)" || true)
  if [ -n "$errors" ]; then
    issues+="$errors"$'\n'
  fi

  local warnings
  warnings=$(echo "$app_logs" | grep -i -E "(WARN|DEPRECAT)" || true)
  if [ -n "$warnings" ]; then
    issues+="$warnings"$'\n'
  fi

  if [ -n "$issues" ]; then
    warn "Issues found in $app logs:"
    echo "$issues" | head -30 | while IFS= read -r line; do
      [ -n "$line" ] && echo "      $line"
    done
    local total
    total=$(echo "$issues" | grep -c . || true)
    if [ "$total" -gt 30 ]; then
      warn "...and $((total - 30)) more (run: heroku logs -n 500 -a $app)"
    fi
  else
    ok "No errors, warnings, or deprecations found"
  fi
}

check_health() {
  local name="$1"
  local url="$2"

  step "Health check: $name"
  info "Curling $url ..."

  local attempts=0
  local max_attempts=12
  local status

  # Heroku dynos can take a moment to boot. Retry for up to 60 seconds.
  while [ $attempts -lt $max_attempts ]; do
    status=$(curl -sL -o /dev/null -w "%{http_code}" "$url" 2>/dev/null || echo "000")

    if [ "$status" = "200" ] || [ "$status" = "302" ]; then
      ok "$url returned HTTP $status"
      return 0
    fi

    attempts=$((attempts + 1))
    if [ $attempts -lt $max_attempts ]; then
      info "Got HTTP $status, retrying in 5s... ($attempts/$max_attempts)"
      sleep 5
    fi
  done

  fail "$url returned HTTP $status after $max_attempts attempts"
  exit 1
}

# --- Main ---------------------------------------------------------------------

main() {
  bold "============================================"
  bold "  Comeals Deploy"
  bold "============================================"

  # --- Pre-flight: environment & repo state ---
  preflight_environment
  preflight_check "Backend"  "$BACKEND_PATH"
  preflight_check "Frontend" "$FRONTEND_PATH"

  # --- Determine what needs deploying ---
  detect_deploy_needs

  if [ "$DEPLOY_BACKEND" = false ] && [ "$DEPLOY_FRONTEND" = false ]; then
    echo
    green "============================================"
    green "  Both apps are up to date — nothing to deploy."
    green "============================================"
    exit 0
  fi

  # Check for pending migrations (only if backend is deploying and we
  # have the heroku SHA to diff against — otherwise NEEDS_MAINTENANCE
  # was already set to true as a safe default in detect_deploy_needs).
  if [ "$DEPLOY_BACKEND" = true ] && [ -n "$BACKEND_HEROKU_SHA" ]; then
    detect_pending_migrations "$BACKEND_HEROKU_SHA"
  fi

  # --- Quality checks (only for apps being deployed) ---
  if [ "$DEPLOY_BACKEND" = true ]; then
    preflight_backend_quality
  fi
  if [ "$DEPLOY_FRONTEND" = true ]; then
    preflight_frontend_quality
  fi

  # --- Confirmation ---
  echo
  bold "Deploy plan:"
  echo

  if [ "$DEPLOY_BACKEND" = true ]; then
    local backend_sha
    backend_sha=$(git -C "$BACKEND_PATH" rev-parse --short HEAD)
    if [ "$NEEDS_MAINTENANCE" = true ]; then
      yellow "    Backend ($backend_sha):  MAINTENANCE deploy (has migrations)"
    else
      green "    Backend ($backend_sha):  PUSH deploy (no migrations)"
    fi
    git -C "$BACKEND_PATH" log --oneline -5 | while IFS= read -r line; do
      info "  $line"
    done
  else
    info "Backend:  SKIP (up to date)"
  fi

  echo
  if [ "$DEPLOY_FRONTEND" = true ]; then
    local frontend_sha
    frontend_sha=$(git -C "$FRONTEND_PATH" rev-parse --short HEAD)
    green "    Frontend ($frontend_sha): PUSH deploy"
    git -C "$FRONTEND_PATH" log --oneline -5 | while IFS= read -r line; do
      info "  $line"
    done
  else
    info "Frontend: SKIP (up to date)"
  fi

  if [ "$NEEDS_MAINTENANCE" = true ]; then
    echo
    yellow "    Both apps will enter maintenance mode during backend migration."
  fi

  echo
  printf "Continue? (y/n) "
  read -r confirm
  if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
    info "Aborted."
    exit 0
  fi

  DEPLOY_TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%S")

  # --- Backup (only when deploying backend — that's the only app with a DB) ---
  if [ "$DEPLOY_BACKEND" = true ]; then
    capture_backup
  fi

  # --- Deploy ---
  if [ "$NEEDS_MAINTENANCE" = true ]; then
    # Maintenance deploy: both apps get maintenance pages while backend
    # migrations run. This is better UX than letting the frontend show
    # broken API errors during the migration window.
    enable_maintenance

    if [ "$DEPLOY_BACKEND" = true ]; then
      deploy_backend_maintenance
    fi
    if [ "$DEPLOY_FRONTEND" = true ]; then
      deploy_frontend_maintenance
    fi

    disable_maintenance
  else
    # Push deploy: brief downtime during dyno restart, no maintenance pages.
    if [ "$DEPLOY_BACKEND" = true ]; then
      deploy_backend
    fi
    if [ "$DEPLOY_FRONTEND" = true ]; then
      deploy_frontend
    fi
  fi

  # --- Post-deploy verification ---
  # Give dynos a moment to boot before checking.
  info "Waiting 10s for dynos to settle..."
  sleep 10

  if [ "$DEPLOY_BACKEND" = true ]; then
    check_logs "$BACKEND_APP"
  fi
  if [ "$DEPLOY_FRONTEND" = true ]; then
    check_logs "$FRONTEND_APP"
  fi

  # Always health-check both apps — even the one we didn't deploy could
  # have been affected (e.g., maintenance mode toggling, shared DB changes).
  check_health "Frontend" "$FRONTEND_URL"
  check_health "Backend"  "$BACKEND_URL"

  echo
  green "============================================"
  green "  Deploy complete!"
  green "============================================"
}

main "$@"
